      <aliases enabled='yes' />
      <column datatype='real' name='[Avg. Session Duration]' role='measure' type='quantitative' />
      <column caption='Conversion Rate' datatype='real' default-format='p0%' name='[Calculation_1173635197620224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([Converted]=&apos;Yes&apos;, 1 , 0))/COUNT([Converted])' />
      </column>
      <column caption='Bounce Rate' datatype='real' default-format='p0%' name='[Calculation_1173635198779393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([Bounce]=&apos;Yes&apos;,1,0))/COUNT([Bounce])' />
      </column>
      <column caption='Total Visits' datatype='integer' name='[Calculation_1173635199488002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sessions])' />
      </column>
      <column caption='Average Session Duration_CF' datatype='real' name='[Calculation_1173635201785860]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Avg. Session Duration])' />
      </column>
      <column caption='Conversion Rate (Daily)' datatype='real' name='[Calculation_1173635223240709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;    IF [Converted] = &quot;Yes&quot; THEN [Sessions] ELSE 0 END&#10;)&#10;/&#10;SUM([Sessions])' />
